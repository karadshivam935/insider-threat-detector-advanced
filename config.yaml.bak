storage:
  sqlite_path: data/itd.db

capture:
  interface: eth0

network:
  employee_subnet: 192.168.235.0/24
  admin_ip: 192.168.235.128

detection:
  window_seconds: 10
  baseline_alpha: 0.2
  baseline_min_windows: 6
  risky_ports: [21,22,23,445,3389,5900]
  port_scan_threshold: 10
  byte_spike_multiplier: 5
  off_hours:
    start: "20:00"
    end: "06:00"

scoring:
  risky_port: 35
  port_scan: 70
  byte_spike: 40
  off_hours: 20
  block_threshold: 70

response:
  auto_block: true
  iptables_chain: ITD_BLOCK

project:
  timezone: Asia/Kolkata

web:
  host: 0.0.0.0
  port: 5000
